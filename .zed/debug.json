// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger

[
  {
    "label": "Debug cppx",
    "adapter": "CodeLLDB",
    "request": "launch",
    "program": "${ZED_WORKTREE_ROOT}/build-debug/cppx",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "build": {
      "command": "bash",
      "args": ["-c", "cmake -B build-debug -DCMAKE_BUILD_TYPE=Debug -S . && cmake --build build-debug"]
    }
  }
]
